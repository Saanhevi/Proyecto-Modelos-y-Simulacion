int nueva_cantidad = main.covidPhysicians.capacity-1;
main.sliderPhysicians.setValue(nueva_cantidad); // Actualiza la posición visual del slider
main.covidPhysicians.set_capacity(nueva_cantidad); // Modifica la capacidad del pool]]></Action>
