						<OccurrenceDate>1784102400000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[int disponibles = 0;
for (PhysicianCovid p : physicianCovids) {
	if (p.inState(PhysicianCovid.Susceptible) || p.inState(PhysicianCovid.Recovered)) {
		disponibles++;
	}
}
covidPhysicians.set_capacity(Math.max(0, disponibles));
if (sliderPhysicians != null) {
	sliderPhysicians.setValue(disponibles);
}
]]></Action>
				</Event>
				<Event>
					<Id>1999410000001</Id>
					<Name><![CDATA[eventKpiWaiting]]></Name>
					<X>970</X><Y>570</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>false</PresentationFlag>
					<ShowLabel>false</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_DAY]]></Unit>
						</Rate>
						<Id>1999410000002</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1784102400000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[0.25]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[if (time() >= 8) {
	double w = queueCovidPatients.size()
		+ queueChildren.size()
		+ queueAdults.size()
		+ respiratoryTriage1.size()
		+ triageRoom2.size();
	kpiWaitSum += w;
	kpiWaitN++;
	kpiWaitAvg = kpiWaitN > 0 ? kpiWaitSum / kpiWaitN : 0;
}
]]></Action>
				</Event>
				<Event>
					<Id>1784406815963</Id>
					<Name><![CDATA[eventoGuardarDiario]]></Name>
					<X>270</X><Y>540</Y>
					<Label><X>110</X><Y>30</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_DAY]]></Unit>
						</Rate>
						<Id>1784406815961</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1784448000000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[// Serie diaria para Fig. 8 (flujo acumulado al hospital).
// Append en Documents para que ParametersVariation junte las 5 curvas (π).
archivoCSV.println(time() + "," + kpiUntreated + "," + probabilityOfTransmission + "," + hospitalFlow);
try {
	java.io.File dir = new java.io.File(System.getProperty("user.home"), "Documents");
	if (!dir.exists()) dir = new java.io.File(System.getProperty("user.home"));
	java.io.File f = new java.io.File(dir, "fig8_flujo_diario_EXPLORA_prodFig8.csv");
	boolean writeHeader = !f.exists() || f.length() == 0;
	java.io.FileWriter fw = new java.io.FileWriter(f, true);
	if (writeHeader) {
		fw.write("day,pTransmit,flujoHospital,untreated\n");
	}
	// Flujo acumulado hacia el hospital (stock ya enviado + pendiente de convertir).
	double flujoAcum = kpiDsToHospital + goToHospital;
	fw.write(String.format(java.util.Locale.US, "%.0f,%.4f,%.2f,%d\n",
		time(), (double) probabilityOfTransmission, flujoAcum, (long) kpiUntreated));
	fw.close();
} catch (Exception e) {
	traceln("No se pudo escribir fig8_flujo_diario_EXPLORA_prodFig8.csv: " + e);
}]]></Action>
				</Event>
			</Events>
