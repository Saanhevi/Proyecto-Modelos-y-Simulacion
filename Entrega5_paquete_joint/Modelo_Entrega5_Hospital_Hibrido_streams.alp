		<ActiveObjectClass>
			<Id>1783897912797</Id>
			<Name><![CDATA[Main]]></Name>
			<AdditionalClassCode><![CDATA[
// Streams independientes (campos publicos; PlainVariable Random no siempre genera campo).
public Random rngSed;
public Random rngAbm;
public Random rngGate;
public Random rngBranch;
]]></AdditionalClassCode>
			<StartupCode><![CDATA[archivoCSV.println("Dia,NoTratados,TasaTransmision,FlujoHospital");
// Streams independientes (experimento). Semillas derivadas del RNG de esta corrida/replica
// para que ExperimentoReplicas (randomSeed) siga produciendo replicas distintas.
long baseSeed = getDefaultRandomGenerator().nextLong();
rngSed = new Random(baseSeed ^ 0xA11CEL);
rngAbm = new Random(baseSeed ^ 0xB0B1L);
rngGate = new Random(baseSeed ^ 0xC0DEL);
rngBranch = new Random(baseSeed ^ 0xD00DL);
traceln("STREAMS init base=" + baseSeed);
// admitidosCovid: cualquier patient que ocupo cama COVID (incluye admision < dia 8).
// kpiTreated (SED joint): egreso en [8,30] si estuvo en admitidosCovid (DischargeInWindow).
// admitidosVentana: solo admisiones en [8,30] para adultAdmit/childAdmit.
admitidosVentana = new java.util.HashSet<Agent>();
admitidosCovid = new java.util.HashSet<Agent>();]]></StartupCode>
			<DestroyCode><![CDATA[// Cierra la serie diaria (Fig. 7/8: no atendidos y flujo por dia)
archivoCSV.close();

// Exporta UNA fila por corrida/replica al terminar (dia 30) para boxplots Tabla 5 / validacion Tabla 3.
// Contadores acumulados 8-30; el script de Python normaliza a /dia lo que corresponde a Tabla 3.
try {
	// Ruta absoluta: el working dir de AnyLogic PLE no es predecible (una ruta
	// relativa puede caer en Program Files y fallar sin aviso).
	java.io.File dir = new java.io.File(System.getProperty("user.home"), "Documents");
	if (!dir.exists()) dir = new java.io.File(System.getProperty("user.home"));
	java.io.File f = new java.io.File(dir, "replicas_kpis_STREAMS.csv");
	boolean writeHeader = !f.exists() || f.length() == 0;
	java.io.FileWriter fw = new java.io.FileWriter(f, true);
	if (writeHeader) {
		fw.write("run_id,pTransmit,arrive,triage,untreated,treated,adultAdmit,childAdmit,discharge,ambulatory,staffInfected,waitAvg,dsToHospital,S,I\n");
	}
	fw.write(String.format(java.util.Locale.US,
		"%d,%.4f,%d,%d,%d,%d,%d,%d,%d,%d,%d,%.4f,%d,%.2f,%.2f\n",
		System.currentTimeMillis(),
		(double) probabilityOfTransmission,
		(long) kpiArriveCovid, (long) kpiTriageResp, (long) kpiUntreated,
		(long) kpiTreated, (long) kpiAdultAdmit, (long) kpiChildAdmit,
		(long) kpiDischargeCovid, (long) kpiAmbulatory, (long) kpiStaffInfected,
		(double) kpiWaitAvg, (long) kpiDsToHospital,
		(double) Susceptible, (double) Infective));
	fw.close();
	traceln(String.format(java.util.Locale.US,
		"%s <- p=%.3f arrive=%d untreated=%d treated=%d adult=%d child=%d",
		f.getAbsolutePath(),
		(double) probabilityOfTransmission,
		(long) kpiArriveCovid, (long) kpiUntreated, (long) kpiTreated,
		(long) kpiAdultAdmit, (long) kpiChildAdmit));
	// Actualiza pantallas de ParametersVariation / ExperimentoReplicas (DestroyCode corre al dia 30).
	try {
		if (getExperiment() instanceof ParametersVariation) {
			ParametersVariation pv = (ParametersVariation) getExperiment();
			pv.uiArrive = (int) kpiArriveCovid;
			pv.uiUntreated = (int) kpiUntreated;
			pv.uiTreated = (int) kpiTreated;
			pv.uiAdult = (int) kpiAdultAdmit;
			pv.uiChild = (int) kpiChildAdmit;
			pv.uiDs = (int) kpiDsToHospital;
		} else if (getExperiment() instanceof ExperimentoReplicas) {
			ExperimentoReplicas er = (ExperimentoReplicas) getExperiment();
			er.uiArrive = (int) kpiArriveCovid;
			er.uiUntreated = (int) kpiUntreated;
			er.uiTreated = (int) kpiTreated;
			er.uiAdult = (int) kpiAdultAdmit;
			er.uiChild = (int) kpiChildAdmit;
			er.uiDs = (int) kpiDsToHospital;
		}
	} catch (Exception e2) {
		traceln("No se pudo actualizar UI del experimento: " + e2);
	}
} catch (Exception e) {
	traceln("No se pudo escribir replicas_kpis_STREAMS.csv: " + e);
}]]></DestroyCode>
