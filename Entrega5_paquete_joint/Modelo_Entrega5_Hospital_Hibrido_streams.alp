							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[int disponibles = 0;
for (AuxiliarNurse a : nurseAuxiliares) {
	if (a.inState(AuxiliarNurse.Susceptible) || a.inState(AuxiliarNurse.Recovered)) {
		disponibles++;
	}
}
auxiliaryNurses.set_capacity(Math.max(0, disponibles));
if (slider2 != null) { slider2.setValue(disponibles); }
]]></Action>
				</Event>
