						<Timeout Class="CodeUnitValue">
							<Code>0</Code>
							<Unit Class="TimeUnits">DAY</Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code>1</Code>
							<Unit Class="RateUnits">PER_DAY</Unit>
						</Rate>
						<Id>1999410000002</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1784102400000</OccurrenceDate>
