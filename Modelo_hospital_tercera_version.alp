							<Code>0.25</Code>
							<Unit Class="TimeUnits">DAY</Unit>
						</RecurrenceCode>
						<Condition>false</Condition>
					</Properties>
					<Action>if (time() &gt;= 8) {
	double w = queueCovidPatients.size()
		+ queueChildren.size()
		+ queueAdults.size()
		+ respiratoryTriage1.size()
		+ triageRoom2.size();
	kpiWaitSum += w;
	kpiWaitN++;
	kpiWaitAvg = kpiWaitN &gt; 0 ? kpiWaitSum / kpiWaitN : 0;
}
</Action>
