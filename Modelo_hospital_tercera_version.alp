			<VmArgs />
			<LoadRootFromSnapshot>false</LoadRootFromSnapshot>

			<AfterReplication>// Exportar KPIs al CSV al finalizar cada réplica
try {
    Main m = (Main) getEngine().getRootObject();
    String csvPath = System.getProperty("user.home") + "/Documents/replicas_kpis.csv";
    java.io.File f = new java.io.File(csvPath);
    boolean writeHeader = !f.exists() || f.length() == 0;
    java.io.PrintWriter pw = new java.io.PrintWriter(new java.io.FileWriter(f, true));
    if (writeHeader) {
        pw.println("replica,kpiArriveCovid,kpiTriageResp,kpiUntreated,kpiTreated,kpiAdultAdmit,kpiChildAdmit,kpiDischargeCovid,kpiAmbulatory,kpiStaffInfected,kpiWaitAvg,kpiDsToHospital");
    }
    pw.println(
        getCurrentReplication() + "," +
        m.kpiArriveCovid + "," +
        m.kpiTriageResp + "," +
        m.kpiUntreated + "," +
        m.kpiTreated + "," +
        m.kpiAdultAdmit + "," +
        m.kpiChildAdmit + "," +
        m.kpiDischargeCovid + "," +
        m.kpiAmbulatory + "," +
        m.kpiStaffInfected + "," +
        String.format("%.4f", m.kpiWaitAvg) + "," +
        m.kpiDsToHospital
    );
    pw.flush();
    pw.close();
} catch(Exception ex) {
    traceln("CSV export error: " + ex.getMessage());
}</AfterReplication><Presentation>
