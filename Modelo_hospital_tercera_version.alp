					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="condition" Mode="occuresOnce">
						<Timeout Class="CodeUnitValue">
							<Code>1</Code>
							<Unit Class="TimeUnits">DAY</Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code>1</Code>
							<Unit Class="RateUnits">PER_DAY</Unit>
						</Rate>
						<Id>1783901629043</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1783929600000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code>0</Code>
							<Unit Class="TimeUnits">DAY</Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code>1</Code>
							<Unit Class="TimeUnits">DAY</Unit>
						</RecurrenceCode>
						<Condition>goToHospital &gt; 0</Condition>
					</Properties>
					<Action>goToHospital--;
kpiDsToHospital++;
orizabaCovidPatients.inject(1);
event.restart();</Action>
				</Event>
				<Event>
