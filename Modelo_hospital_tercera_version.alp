							<Name>onExitTrue</Name>
						</Parameter>
						<Parameter>
							<Name>onExitFalse</Name>
							<Value Class="CodeValue">
								<Code>// Calib. Rust: p_amb=0.974 y p_seize_ok=0.222 → True=0.216 a triage.
// False=0.784 se reparte en ambulatorios reales (~0.026) y no atendidos por cupo (~0.758).
if (time() &gt;= 8) {
	if (uniform() &lt; 0.026 / 0.784) { kpiAmbulatory++; }
	else { kpiUntreated++; }
}</Code>
							</Value>
						</Parameter>
